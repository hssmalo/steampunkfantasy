default: check

# Run all quality gates in order, stopping on the first failure.
check: fmt-check lint validate spell test typecheck 

# Auto-format the codebase with ruff.
fmt:
    uv run ruff format -q

# Check formatting without writing changes.
fmt-check:
    uv run ruff format --check -q

# Lint the codebase with ruff.
lint:
    uv run ruff check -q

# Type-check src/ and tests/ with pyright.
typecheck:
    uv run pyright

# Spell-check the codebase with typos.
spell:
    uv run typos

# Fix spelling errors with typos.
spell-fix:
    uv run typos --write-changes

# Run the test suite quietly.
test *args:
    uv run pytest -q {{args}}

# Auto-fix lint issues then reformat.
fix:
    uv run ruff check --fix -q
    uv run ruff format -q

# Validate all toml files
validate:
    uv run spf race show abomination > /dev/null
    uv run spf race show darkelf > /dev/null
    uv run spf race show elf > /dev/null
    uv run spf race show goblin > /dev/null
    uv run spf race show ork > /dev/null
    uv run spf race show ogre > /dev/null
    uv run spf rules hexes > /dev/null
    uv run spf rules specials > /dev/null
    uv run spf rules tokens > /dev/null
    